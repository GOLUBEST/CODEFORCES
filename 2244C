#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        int n, x, y;
        cin >> n >> x >> y;
        vector<int> p(n + 1);
        for (int i = 1; i <= n; i++) cin >> p[i];

        int g = std::gcd(x, y);
        vector<int> pos(n + 1);
        for (int i = 1; i <= n; i++) pos[p[i]] = i;

        bool ok = true;
        for (int v = 1; v <= n; v++) {
            if ((pos[v] - v) % g != 0) {
                ok = false;
                break;
            }
        }

        cout << (ok ? "YES" : "NO") << '\n';
    }

    return 0;
}
