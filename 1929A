#include<bits/stdc++.h>
using namespace std;

int main() {

    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        vector<int> arr;

        for(int i = 0 ; i < n ; i++){
            int a;
            cin >> a;

            arr.push_back(a);
        }

        int sum = 0;

        sort(arr.begin() , arr.end());

        for(int i = 1 ; i < n ; i++) {
            sum += (arr[i] - arr[i-1]);
        }

        cout << sum << endl;
    }

    return 0;
}
