#include <iostream>

using namespace std;

void solve() {
    int n;
    cin >> n;
    
    int h1, h2, h3;
    int k = n / 3;
    
    if (n % 3 == 0) {
        h2 = k;
        h1 = k + 1;
        h3 = k - 1;
    } else if (n % 3 == 1) {
        h2 = k;
        h1 = k + 2;
        h3 = k - 1;
    } else { // n % 3 == 2
        h2 = k + 1;
        h1 = k + 2;
        h3 = k - 1;
    }
    
    // Output format is required to be: h2, h1, h3
    cout << h2 << " " << h1 << " " << h3 << "\n";
}

int main() {
    // Fast I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    
    return 0;
}
