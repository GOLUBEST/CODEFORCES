#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> a(n);
        for (int i = 0; i < n; i++) cin >> a[i];
        sort(a.begin(), a.end());

        int ans = n;
        for (int i = 0; i < n; ) {
            int j = i;
            while (j < n && a[j] == a[i]) j++;
            int L = i;       // count of elements < a[i]
            int R = n - j;   // count of elements > a[i]
            ans = min(ans, max(L, R));
            i = j;
        }
        cout << ans << "\n";
    }
    return 0;
}
