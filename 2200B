#include<bits/stdc++.h>
using namespace std;

int main(){
    int t;
    cin >> t;
    
    while(t--) {
        int n;
        cin >> n;
        
        int arr[n];
        
        for(int i = 0 ; i < n ; i++) {
            cin >> arr[i];
        }
        
        int flag = 0;
        
        for(int i = 1 ; i < n ; i++) {
            if(arr[i-1] > arr[i]){
                flag = 1;
                break;
            }
        }
        
        if(!flag) cout << n << endl;
        else cout << 1 << endl;
    }
    return 0;
}
