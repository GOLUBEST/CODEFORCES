#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T; 
    cin >> T;
    while (T--) {
        int n;
        cin >> n;
        vector<long long> a(n), b(n);
        for (int i = 0; i < n; i++) cin >> a[i];
        for (int i = 0; i < n; i++) cin >> b[i];

        // Easy version limitation
        if (n > 20) {
            cout << "This easy DP version is only for small n (<=20)\n";
            continue;
        }

        const long long INF = (long long)4e18;
        int N = 1 << n;
        vector<long long> dp(N, INF);
        dp[0] = 0;

        for (int mask = 0; mask < N; mask++) {
            int i = __builtin_popcount((unsigned)mask); // next pile index in a
            if (i >= n || dp[mask] == INF) continue;

            for (int j = 0; j < n; j++) {
                if (mask & (1 << j)) continue;      // target j already used
                if (a[i] > b[j]) continue;          // cannot decrease ducks

                // added inversions: used targets with index > j
                int bigger = 0;
                for (int k = j + 1; k < n; k++) {
                    if (mask & (1 << k)) bigger++;
                }

                int nmask = mask | (1 << j);
                dp[nmask] = min(dp[nmask], dp[mask] + bigger);
            }
        }

        long long ans = dp[N - 1];
        if (ans >= INF / 2) cout << -1 << '\n';
        else cout << ans << '\n';
    }

    return 0;
}222
