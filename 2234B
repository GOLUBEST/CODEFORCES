#include <iostream>

using namespace std;

void solve() {
    long long n;
    if (!(cin >> n)) return;
    long long k = n % 12;
    if (k != 10) {
        cout << k << " " << n - k << "\n";
    } else {
        if (n < 22) {
            cout << -1 << "\n";
        } else {
            cout << 22 << " " << n - 22 << "\n";
        }
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    if (cin >> t) {
        while (t--) {
            solve();
        }
    }
    return 0;
}
