#include <iostream>
#include <vector>

using namespace std;

void solve() {
    int n;
    cin >> n;
    
    vector<int> a(2 * n);
    vector<bool> seen(n + 1, false);
    vector<int> p;
    
    for (int i = 0; i < 2 * n; ++i) {
        cin >> a[i];
        // If the number hasn't been encountered yet
        if (!seen[a[i]]) {
            p.push_back(a[i]);
            seen[a[i]] = true; // Mark it as seen
        }
    }
    
    // Print the restored permutation
    for (int i = 0; i < n; ++i) {
        cout << p[i] << (i == n - 1 ? "" : " ");
    }
    cout << "\n";
}

int main() {
    // Fast I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    
    return 0;
}
