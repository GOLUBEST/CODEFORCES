#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> p(n);
        for (int i = 0; i < n; i++) cin >> p[i];
        
        int ans = (n == 1) ? 1 : 2;
        for (int i = 0; i < n; i++) {
            if (i > 0) cout << " ";
            cout << ans;
        }
        cout << "\n";
    }
    return 0;
}
