#include <bits/stdc++.h>
using namespace std;

const int INF = 1e9;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n, k;
        cin >> n >> k;

        string s;
        cin >> s;

        vector<vector<int>> dp(n + 1, vector<int>(n + 1, INF));

        // Base case
        for (int r = 0; r <= n; r++) {
            if (r >= k)
                dp[n][r] = 0;
        }

        for (int i = n - 1; i >= 0; i--) {
            for (int r = 0; r <= n; r++) {

                // Put L here
                if (r >= k) {
                    dp[i][r] = min(dp[i][r],
                                   (s[i] == 'R') + dp[i + 1][r]);
                }

                // Put R here
                if (n - i - 1 >= k && r + 1 <= n) {
                    dp[i][r] = min(dp[i][r],
                                   (s[i] == 'L') + dp[i + 1][r + 1]);
                }
            }
        }

        if (dp[0][0] >= INF)
            cout << -1 << '\n';
        else
            cout << dp[0][0] << '\n';
    }

    return 0;
}
