#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while (t--) {
        int n, k, p, m;
        cin >> n >> k >> p >> m;

        vector<int> a(n+1);
        for (int i = 1; i <= n; i++)
            cin >> a[i];

        if (p <= k) {
            cout << m / a[p] << "\n";
            continue;
        }

        int cost = 0;

        for (int i = 1; i <= p - k; i++)
            cost += a[i];

        if (cost > m) {
            cout << 0 << "\n";
            continue;
        }

        int remaining = m - cost;
        cout << 1 + remaining / a[p] << "\n";
    }
}
