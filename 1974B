#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        string b;
        cin >> b;

        // Step 1: get distinct characters and sort
        set<char> st(b.begin(), b.end());
        vector<char> r(st.begin(), st.end());

        // Step 2: create mapping
        unordered_map<char, char> mp;
        int m = r.size();

        for(int i = 0; i < m; i++) {
            mp[r[i]] = r[m - i - 1];
        }

        // Step 3: decode
        string s = "";
        for(char c : b) {
            s += mp[c];
        }

        cout << s << "\n";
    }

    return 0;
}
