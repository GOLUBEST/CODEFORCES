#include <bits/stdc++.h>
using namespace std;

using int64 = long long;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int64> a(n);
        for (int i = 0; i < n; ++i) cin >> a[i];

        int64 cur = a[0];
        int64 ans = cur;

        for (int i = 1; i < n; ++i) {
            if (cur <= a[i]) cur = a[i];
            else cur = cur + a[i];
            if (cur > ans) ans = cur;
        }

        cout << ans << '\n';
    }
    return 0;
}
