#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        int k;
        cin >> k;
        vector<long long> c(k);

        long long mx = 0;
        int cnt2 = 0;

        for (int i = 0; i < k; i++) {
            cin >> c[i];
            mx = max(mx, c[i]);
            if (c[i] == 2) cnt2++;
        }

        if (mx >= 3 || cnt2 >= 2) {
            cout << "YES\n";
        } else {
            cout << "NO\n";
        }
    }

    return 0;
}
