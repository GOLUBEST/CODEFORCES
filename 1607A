#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        string keyboard, s;
        cin >> keyboard >> s;

        // store position of each character
        int pos[26];
        for(int i = 0; i < 26; i++) {
            pos[keyboard[i] - 'a'] = i;
        }

        int time = 0;

        // calculate time
        for(int i = 1; i < s.length(); i++) {
            int prev = pos[s[i-1] - 'a'];
            int curr = pos[s[i] - 'a'];
            time += abs(curr - prev);
        }

        cout << time << endl;
    }

    return 0;
}
