#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int t;
    if (!(cin >> t)) return 0;
    while (t--) {
        int n;
        cin >> n;
        int x = 0;
        for (int i = 0; i < n; ++i) {
            int a;
            cin >> a;
            x ^= a;
        }
        if (n % 2 == 1) {
            cout << x << '\n';
        } else {
            if (x == 0) cout << 0 << '\n';
            else cout << -1 << '\n';
        }
    }
    return 0;
}
