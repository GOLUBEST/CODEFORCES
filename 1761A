#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int t;
    if (!(cin >> t)) return 0;
    while (t--) {
        int n, a, b;
        cin >> n >> a >> b;
        if (n == 1) {
            cout << ((a == 1 && b == 1) ? "Yes\n" : "No\n");
        } else {
            if (a + b <= n - 2) cout << "Yes\n";
            else cout << "No\n";
        }
    }
    return 0;
}
