#include <iostream>

using namespace std;

void solve() {
    int n;
    cin >> n;
    int s = 1;
    int l = 3 * n;
    
    for (int i = 0; i < n; ++i) {
        cout << s << " " << l - 1 << " " << l << " ";
        s++;
        l -= 2;
    }
    cout << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    if (cin >> t) {
        while (t--) {
            solve();
        }
    }
    return 0;
}
