#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        string s;
        cin >> s;
        int n = s.size();
        bool ok = false;
        for (int start = 0; start < 2; start++) {
            int first = -1, last = -1, cnt = 0;
            for (int i = 0; i < n; i++) {
                char expected = ((i + start) % 2 == 0) ? 'a' : 'b';
                if (s[i] != expected) {
                    cnt++;
                    if (first == -1) first = i;
                    last = i;
                }
            }
            if (cnt == 0 || last - first + 1 == cnt) {
                ok = true;
                break;
            }
        }
        cout << (ok ? "YES" : "NO") << "\n";
    }
    return 0;
}
