#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        string n;
        cin >> n;

        int cursor = 1;
        int cnt = 0;

        for (int i = 0; i < 4; i++) {
            int a = n[i] - '0';

            if (a == 0) 
                a = 10;

            cnt += abs(a - cursor) + 1;
            cursor = a;
        }

        cout << cnt << endl;
    }

    return 0;
}
