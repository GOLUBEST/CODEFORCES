#include <bits/stdc++.h>
using namespace std;

using int64 = long long;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        long long n, k;
        cin >> n >> k;

        long long ans = 0;
        long long cost = 1; // current layer bit cost: 1,2,4,...

        // In each layer, we can place at most k bits, each costs 'cost'
        while (cost <= n) {
            long long canBuy = n / cost;          // max bits affordable at this layer cost
            long long take = min(k, canBuy);      // capped by k numbers
            ans += take;
            n -= take * cost;
            if (take < k) break; // can't fill this layer fully => no higher layer possible
            if (cost > (long long)4e18 / 2) break;
            cost <<= 1;
        }

        cout << ans << '\n';
    }

    return 0;
}
