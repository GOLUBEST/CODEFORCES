#include<bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;
        
        int arr[n];
        int sum = 0;
        for(int i = 0 ; i < n ; i++) {
            cin >> arr[i];
            sum += arr[i];
        }

        // for odd length
        if(n % 2 != 0) {
            cout << "NO" << endl;
            continue;
        } 
        
        // for even length
        if(sum == 0 || sum % 4 == 0) {
            cout << "YES" << endl;
        }
        else{
            cout << "NO" << endl;
        }
    }

    return 0;
}
