#include <bits/stdc++.h>
using namespace std;

const int MOD = 676767677;

long long countDivisors(int n) {
    long long cnt = 0;
    for (int i = 1; (long long)i * i <= n; i++) {
        if (n % i == 0) {
            cnt++;
            if (i != n / i) cnt++;
        }
    }
    return cnt;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while (t--) {
        int x, y;
        cin >> x >> y;

        int S = x - y;

        long long ans = (S == 0) ? 1 : countDivisors(abs(S));
        cout << ans % MOD << "\n";

        bool first = true;
        if (S >= 0) {
            // All 1s first, then all -1s
            for (int i = 0; i < x; i++) { if (!first) cout << " "; cout << 1;  first = false; }
            for (int i = 0; i < y; i++) { if (!first) cout << " "; cout << -1; first = false; }
        } else {
            // All -1s first, then all 1s
            for (int i = 0; i < y; i++) { if (!first) cout << " "; cout << -1; first = false; }
            for (int i = 0; i < x; i++) { if (!first) cout << " "; cout << 1;  first = false; }
        }
        cout << "\n";
    }
    return 0;
}
