#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;

        if (n == 1) {
            cout << 1 << '\n';
            continue;
        }

        if (n % 2 == 1) {
            cout << -1 << '\n';
            continue;
        }
        vector<long long> a;
        for (int i = 2; i <= n; i += 2) a.push_back(i);
        for (int i = 1; i <= n - 1; i += 2) a.push_back(i);

        for (int i = 0; i < n; i++) {
            cout << a[i] << (i + 1 == n ? '\n' : ' ');
        }
    }

    return 0;
}
