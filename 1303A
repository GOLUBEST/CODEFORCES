#include<bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;
    while(t--) {
        string s;
        cin >> s;

        int i = 0 , j = s.length() - 1;

        while(i < s.length() && s[i] == '0') i++;

        while(j >= 0 && s[j] == '0') j--;

        int countZero = 0;
        while(i <= j) {
            if(s[i] == '0') countZero++;
            i++;
        }

        cout << countZero << endl;
    }
}
