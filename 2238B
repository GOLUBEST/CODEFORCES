#include <bits/stdc++.h>
using namespace std;

using int64 = long long;

static const int MAXN = 200000;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    // Precompute phi up to MAXN (linear sieve)
    vector<int> phi(MAXN + 1), primes;
    vector<bool> isComp(MAXN + 1, false);
    phi[1] = 1;
    for (int i = 2; i <= MAXN; i++) {
        if (!isComp[i]) {
            primes.push_back(i);
            phi[i] = i - 1;
        }
        for (int p : primes) {
            long long v = 1LL * i * p;
            if (v > MAXN) break;
            isComp[v] = true;
            if (i % p == 0) {
                phi[v] = phi[i] * p;
                break;
            } else {
                phi[v] = phi[i] * (p - 1);
            }
        }
    }

    // pref[n] = sum_{k=1..n} (2*k - 1) * phi[k]
    vector<long long> pref(MAXN + 1, 0);
    pref[1] = 1; // (2*1 - 1)*phi(1) = 1
    for (int k = 2; k <= MAXN; k++) {
        pref[k] = pref[k - 1] + 1LL * (2LL * k - 1) * phi[k];
    }

    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        cout << pref[n] << '\n';
    }

    return 0;
}
